<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="apple-touch-icon" href="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e6/Noto_Emoji_KitKat_1f3cb.svg/1024px-Noto_Emoji_KitKat_1f3cb.svg.png">
  <title>יומן אימונים</title>

  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  
  <style>
    body { margin: 0; padding: 0; background: #04080f; -webkit-tap-highlight-color: transparent; }
    input[type="datetime-local"]::-webkit-calendar-picker-indicator { filter: invert(1); cursor: pointer; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1c2b4b; border-radius: 4px; }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useCallback } = React;

    const DEF_EX_A = [
      { id: "squat", name: "סקוואט מלא", nameEn: "Full Squat", sets: 4, reps: "4-6", hasWarmup: true, type: "weight" },
      { id: "rdl", name: "דדליפט רומני", nameEn: "RDL", sets: 4, reps: "4-6", hasWarmup: true, type: "weight" },
      { id: "bench", name: "לחיצת חזה", nameEn: "Bench Press", sets: 4, reps: "4-6", hasWarmup: true, type: "weight" },
      { id: "pullups", name: "מתח", nameEn: "Pull-ups", sets: 3, reps: "4-6", type: "weight" },
      { id: "seated_row", name: "חתירה במכונה", nameEn: "Seated Row", sets: 4, reps: "8-10", type: "weight" },
      { id: "dead_hang", name: "תלייה על מתח", nameEn: "Dead Hang", sets: 2, reps: "max", type: "time" },
      { id: "woodchop", name: "קוצץ עצים", nameEn: "Cable Woodchop", sets: 3, reps: "8-10", type: "weight", perSide: true },
      { id: "plank", name: "פלאנק", nameEn: "Plank", sets: 2, reps: "60-90s", type: "time" }
    ];
    const DEF_EX_B = [
      { id: "ohp", name: "לחיצת כתפיים בישיבה", nameEn: "Seated DB Press", sets: 3, reps: "6-8", type: "weight" },
      { id: "pullups_b", name: "מתח", nameEn: "Pull-ups", sets: 3, reps: "6/max", type: "weight" },
      { id: "lunges", name: "לאנג׳ים", nameEn: "Lunges", sets: 3, reps: "8-10", type: "weight", perSide: true },
      { id: "good_morning", name: "גוד מורנינג", nameEn: "Good Morning", sets: 4, reps: "6", hasWarmup: true, type: "weight" },
      { id: "cossack", name: "סקוואט קוזאקים", nameEn: "Cossack Squat", sets: 3, reps: "6-8", type: "weight", perSide: true },
      { id: "hip_flexion", name: "כפיפת ירך", nameEn: "Cable Hip Flexion", sets: 2, reps: "8-10", type: "weight", perSide: true, superset: "hip" },
      { id: "hip_abduction", name: "הרחקת ירך", nameEn: "Cable Hip Abduction", sets: 2, reps: "8-10", type: "weight", perSide: true, superset: "hip" },
      { id: "calf_raise", name: "הרמת עקבים", nameEn: "Calf Raise", sets: 3, reps: "10-12", type: "weight" },
      { id: "triceps_ext", name: "פשיטת מרפקים", nameEn: "Overhead Triceps Ext", sets: 3, reps: "6-8", type: "weight", superset: "arms" },
      { id: "incline_curl", name: "כפיפת מרפקים", nameEn: "Incline DB Curl", sets: 3, reps: "6-8", type: "weight", superset: "arms" },
      { id: "russian_twist", name: "טוויסט רוסי", nameEn: "Russian Twist", sets: 2, reps: "8", type: "weight" }
    ];

    const DEF_GOALS = {
      squat: { value: 85, unit: "ק״ג" }, rdl: { value: 120, unit: "ק״ג" }, bench: { value: 70, unit: "ק״ג" },
      pullups: { value: 25, unit: "ק״ג" }, seated_row: { value: 80, unit: "ק״ג" }, dead_hang: { value: 75, unit: "שנ׳" },
      woodchop: { value: 60, unit: "ק״ג" }, plank: { value: 90, unit: "שנ׳" }, ohp: { value: 26, unit: "ק״ג" },
      pullups_b: { value: 25, unit: "ק״ג" }, lunges: { value: 25, unit: "ק״ג" }, good_morning: { value: 80, unit: "ק״ג" },
      cossack: { value: 40, unit: "ק״ג" }, hip_flexion: { value: 50, unit: "ק״ג" }, hip_abduction: { value: 25, unit: "ק״ג" },
      calf_raise: { value: 60, unit: "ק״ג" }, triceps_ext: { value: 35, unit: "ק״ג" }, incline_curl: { value: 20, unit: "ק״ג" },
      russian_twist: { value: 20, unit: "ק״ג" }
    };

    const DATA_KEY = "moshe-workouts-v2";
    const ACTIVITY_TYPES = [{ id: "swim", name: "שחייה", icon: "🏊" }, { id: "stairs", name: "מדרגות", icon: "🪜" }, { id: "climb", name: "טיפוס", icon: "🧗" }];

    const T = {
      bg: "#04080f", card: "rgba(15, 25, 45, 0.85)", cardSolid: "#0f192d", blue: "#3b82f6", blueLight: "#60a5fa", 
      blueGlow: "rgba(59, 130, 246, 0.12)", blueGlow2: "rgba(59, 130, 246, 0.25)", cyan: "#22d3ee", white: "#f1f5f9",
      dim: "#64748b", dimLight: "#94a3b8", border: "rgba(59, 130, 246, 0.12)", borderLight: "rgba(148, 163, 184, 0.15)", 
      success: "#10b981", successGlow: "rgba(16, 185, 129, 0.15)", warn: "#f59e0b", warnGlow: "rgba(245, 158, 11, 0.15)", 
      danger: "#ef4444", purple: "#a78bfa", purpleGlow: "rgba(167, 139, 250, 0.15)"
    };

    const inputStyle = { background: "rgba(15, 25, 45, 0.6)", border: "1px solid " + T.borderLight, borderRadius: 10, padding: "11px 10px", color: T.white, fontSize: 15, outline: "none", direction: "ltr", textAlign: "center", width: "100%", boxSizing: "border-box" };

    function hasFilled(s, t) { return t === "time" ? s.time !== "" && s.time !== undefined : (s.weight !== "" && s.weight !== undefined) && (s.reps !== "" && s.reps !== undefined); }

    async function loadAll() {
      try { const r = localStorage.getItem(DATA_KEY); if (r) return { data: JSON.parse(r), status: "ok" }; } catch (e) { }
      return { data: null, status: "empty" };
    }
    async function saveAll(data) {
      try { localStorage.setItem(DATA_KEY, JSON.stringify(data)); return "ok"; } catch (e) { return "err"; }
    }

    const fmtD = (iso) => new Date(iso).toLocaleDateString("he-IL", { day: "numeric", month: "short" });
    const fmtDY = (iso) => new Date(iso).toLocaleDateString("he-IL", { day: "numeric", month: "short", year: "numeric" });
    const fmtT = (iso) => new Date(iso).toLocaleTimeString("he-IL", { hour: "2-digit", minute: "2-digit" });
    const toLocalISO = (iso) => {
      const d = new Date(iso);
      const pad = (n) => n < 10 ? '0' + n : n;
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    };

    function WorkoutTracker() {
      const [view, setView] = useState("home");
      const [workouts, setWorkouts] = useState([]);
      const [bodyLogs, setBodyLogs] = useState([]);
      const [activities, setActivities] = useState([]);
      const [templates, setTemplates] = useState({ A: DEF_EX_A, B: DEF_EX_B });
      const [goals, setGoals] = useState(DEF_GOALS);
      
      const [cw, setCw] = useState(null);
      const [editingId, setEditingId] = useState(null);
      const [loading, setLoading] = useState(true);
      const [expEx, setExpEx] = useState(null);
      const [hFilter, setHFilter] = useState("all");
      const [notif, setNotif] = useState(null);
      const [selActivity, setSelActivity] = useState(null);
      const [actDur, setActDur] = useState("");
      const [actNote, setActNote] = useState("");
      const [confirmDel, setConfirmDel] = useState(null);
      const [backupModal, setBackupModal] = useState(null);
      
      const [newEx, setNewEx] = useState({ type: "A", name: "", nameEn: "", sets: 3, reps: "8-10", hasWarmup: false, exType: "weight" });

      const notify = (m) => { setNotif(m); setTimeout(() => setNotif(null), 2500); };

      const persist = useCallback(async (w, b, a, t, g) => {
        await saveAll({ workouts: w, bodyLogs: b, activities: a, templates: t, goals: g, savedAt: new Date().toISOString() });
      }, []);

      useEffect(() => {
        (async () => {
          const { data } = await loadAll();
          if (data) {
            setWorkouts(data.workouts || []); setBodyLogs(data.bodyLogs || []); setActivities(data.activities || []);
            setTemplates(data.templates || { A: DEF_EX_A, B: DEF_EX_B }); setGoals(data.goals || DEF_GOALS);
          }
          setLoading(false);
        })();
      }, []);

      const saveT = async (t) => { setTemplates(t); await persist(workouts, bodyLogs, activities, t, goals); notify("תבנית עודכנה ✓"); };
      const saveG = async (g) => { setGoals(g); await persist(workouts, bodyLogs, activities, templates, g); notify("יעדים נשמרו ✓"); };

      const startWorkout = (type) => {
        const exs = templates[type] || (type === "A" ? DEF_EX_A : DEF_EX_B);
        const last = workouts.find(w => w.type === type);
        setCw({ id: Date.now().toString(), type, date: new Date().toISOString(), notes: "",
        exercises: exs.map(ex => { const prev = last ? last.exercises.find(e => e.id === ex.id) : null;
        if (prev && !prev.skipped) return { ...ex, skipped: false, sets_data: prev.sets_data.map(s => ({ ...s })) };
        return { ...ex, skipped: prev?.skipped || false, sets_data: Array.from({ length: parseInt(ex.sets) + (ex.hasWarmup ? 1 : 0) }, (_, i) => ({ isWarmup: ex.hasWarmup && i === 0, weight: "", reps: "", time: "" })) }; }),
        }); setView("active"); setExpEx(0);
      };

      const updateSet = (ei, si, f, v) => setCw(p => { const n = JSON.parse(JSON.stringify(p)); n.exercises[ei].sets_data[si][f] = v; return n; });
      const toggleSkip = (ei) => setCw(p => { const n = JSON.parse(JSON.stringify(p)); n.exercises[ei].skipped = !n.exercises[ei].skipped; return n; });
      const addSet = (ei) => setCw(p => { const n = JSON.parse(JSON.stringify(p)); n.exercises[ei].sets_data.push({ isWarmup: false, weight: "", reps: "", time: "" }); return n; });
      const removeSet = (ei) => setCw(p => { const n = JSON.parse(JSON.stringify(p)); const s = n.exercises[ei].sets_data; for (let i = s.length - 1; i >= 0; i--) { if (!s[i].isWarmup) { s.splice(i, 1); break; } } return n; });

      const finish = async () => {
        if (!cw) return; const done = { ...cw, finishedAt: new Date().toISOString() }; const was = !!editingId;
        const upd = editingId ? workouts.map(w => w.id === editingId ? done : w) : [done, ...workouts];
        if (editingId) setEditingId(null);
        setWorkouts(upd); await persist(upd, bodyLogs, activities, templates, goals);
        setCw(null); setView(was ? "history" : "home"); notify(was ? "עודכן ✏️" : "נשמר! 🎯");
      };
      
      const editW = (w) => { setEditingId(w.id); setCw(JSON.parse(JSON.stringify(w))); setView("active"); setExpEx(0); };
      const deleteW = async (id) => { const upd = workouts.filter(w => w.id !== id); setWorkouts(upd); await persist(upd, bodyLogs, activities, templates, goals); notify("נמחק"); };

      const getHistory = (eid) => workouts.filter(w => w.exercises?.some(e => e.id === eid && !e.skipped)).map(w => {
        const ex = w.exercises.find(e => e.id === eid); const ws = ex.sets_data.filter(s => !s.isWarmup && hasFilled(s, ex.type));
        return { date: w.date, maxW: Math.max(0, ...ws.map(s => parseFloat(s.weight) || 0)), maxT: Math.max(0, ...ws.map(s => parseFloat(s.time) || 0)) };
      }).reverse();

      const makeBackup = () => JSON.stringify({ workouts, bodyLogs, activities, templates, goals, backupDate: new Date().toISOString() }, null, 2);
      
      const downloadJSON = () => {
        const blob = new Blob([makeBackup()], { type: "application/json" });
        const a = document.createElement("a"); a.href = URL.createObjectURL(blob);
        a.download = `workout_backup_${new Date().toISOString().slice(0,10)}.json`; a.click();
      };
      
      const handleFileUpload = (e) => {
        const file = e.target.files[0]; if (!file) return;
        const reader = new FileReader();
        reader.onload = async (evt) => {
          try {
            const d = JSON.parse(evt.target.result);
            if (d.workouts) {
              setWorkouts(d.workouts); setBodyLogs(d.bodyLogs || []); setActivities(d.activities || []);
              if (d.templates) setTemplates(d.templates); if (d.goals) setGoals(d.goals);
              await persist(d.workouts, d.bodyLogs || [], d.activities || [], d.templates || templates, d.goals || goals);
              setBackupModal(null); notify("שוחזר בהצלחה! ✓");
            } else throw new Error("bad format");
          } catch (err) { notify("שגיאה בקובץ"); }
        };
        reader.readAsText(file);
      };

      const exportText = (list) => {
        if (!list.length) return "אין נתונים.";
        const L = [];
        list.forEach(w => { L.push("— אימון " + w.type + " | " + fmtDY(w.date) + " —");
        w.exercises.forEach(ex => { if (ex.skipped) return;
        const ws = ex.sets_data.filter(s => !s.isWarmup && hasFilled(s, ex.type)); const wu = ex.sets_data.find(s => s.isWarmup && hasFilled(s, ex.type));
        if (!ws.length && !wu) return; const str = ex.type === "time" ? ws.map(s => s.time + "s").join(", ") : ws.map(s => s.weight + "×" + s.reps).join(", ");
        L.push("  " + ex.name + ": " + str + (wu ? " [W:" + wu.weight + "×" + wu.reps + "]" : "")); });
        if (w.notes) L.push("  הערות: " + w.notes); L.push(""); });
        return L.join("\n");
      };

      if (loading) return <div style={{ background: T.bg, minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center", color: T.blue, fontSize: 18, fontFamily: "sans-serif" }}>טוען...</div>;

      const css = `@import url('https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap');`;
      const font = "'Heebo', 'SF Pro Display', -apple-system, sans-serif";
      
      const Notif = () => notif ? <div style={{ position: "fixed", top: 20, left: "50%", transform: "translateX(-50%)", background: T.success, color: "#fff", padding: "10px 28px", borderRadius: 50, zIndex: 999, fontSize: 14, fontWeight: 600, fontFamily: font, boxShadow: "0 8px 32px rgba(16,185,129,0.35)" }}>{notif}</div> : null;
      
      const ConfirmModal = () => confirmDel ? (
      <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.75)", zIndex: 999, display: "flex", alignItems: "center", justifyContent: "center", padding: 20 }} onClick={() => setConfirmDel(null)}>
      <div style={{ background: T.cardSolid, borderRadius: 20, padding: 28, maxWidth: 300, width: "100%", border: "1px solid " + T.borderLight, textAlign: "center", fontFamily: font }} onClick={e => e.stopPropagation()}>
      <div style={{ fontSize: 16, fontWeight: 600, color: T.white, marginBottom: 20 }}>{confirmDel.msg}</div>
      <div style={{ display: "flex", gap: 12 }}>
      <button onClick={() => setConfirmDel(null)} style={{ flex: 1, padding: 14, borderRadius: 12, border: "1px solid " + T.borderLight, background: "transparent", color: T.dimLight, fontSize: 15, cursor: "pointer", fontFamily: font }}>ביטול</button>
      <button onClick={async () => { await confirmDel.action(); setConfirmDel(null); }} style={{ flex: 1, padding: 14, borderRadius: 12, border: "none", background: T.danger, color: "#fff", fontSize: 15, fontWeight: 700, cursor: "pointer", fontFamily: font }}>אישור</button>
      </div></div></div>) : null;

      const BackupModal = () => backupModal ? (
      <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.8)", zIndex: 999, display: "flex", alignItems: "center", justifyContent: "center", padding: 20 }} onClick={() => setBackupModal(null)}>
      <div style={{ background: T.cardSolid, borderRadius: 20, padding: 24, maxWidth: 480, width: "100%", border: "1px solid " + T.border, fontFamily: font }} onClick={e => e.stopPropagation()}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 20 }}><span style={{ fontSize: 18, fontWeight: 800, color: T.white }}>💾 ניהול נתונים</span><button onClick={() => setBackupModal(null)} style={{ background: "none", border: "none", color: T.dim, fontSize: 20, cursor: "pointer" }}>✕</button></div>
      <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
      <button onClick={downloadJSON} style={{ padding: 14, borderRadius: 12, border: "none", background: T.blue, color: "#fff", fontSize: 15, fontWeight: 700, cursor: "pointer", fontFamily: font }}>📥 הורד קובץ גיבוי מלא (.json)</button>
      <label style={{ padding: 14, borderRadius: 12, border: "1px solid " + T.blue, background: T.blueGlow, color: T.blueLight, fontSize: 15, fontWeight: 700, cursor: "pointer", fontFamily: font, textAlign: "center", display: "block" }}>
        📤 העלה קובץ לשחזור <input type="file" accept=".json" style={{ display: "none" }} onChange={handleFileUpload} />
      </label>
      <div style={{ height: 1, background: T.border, margin: "10px 0" }}></div>
      <button onClick={() => { navigator.clipboard.writeText(exportText(workouts.slice(0,1))).then(() => notify("הועתק ללוח!")); }} style={{ padding: 14, borderRadius: 12, border: "1px solid " + T.borderLight, background: "transparent", color: T.white, fontSize: 14, cursor: "pointer", fontFamily: font }}>📋 העתק טקסט של האימון האחרון</button>
      <button onClick={() => { navigator.clipboard.writeText(exportText(workouts)).then(() => notify("הועתק ללוח!")); }} style={{ padding: 14, borderRadius: 12, border: "1px solid " + T.borderLight, background: "transparent", color: T.white, fontSize: 14, cursor: "pointer", fontFamily: font }}>📋 העתק טקסט של כל האימונים</button>
      </div></div></div>) : null;

      const Nav = () => (
      <div style={{ position: "fixed", bottom: 0, left: 0, right: 0, background: "rgba(4,8,15,0.92)", backdropFilter: "blur(20px)", borderTop: "1px solid " + T.border, display: "flex", justifyItems: "center", justifyContent: "space-evenly", padding: "8px 0 12px", zIndex: 50 }}>
      {[{ v: "home", i: "⬡", l: "בית" }, { v: "history", i: "☰", l: "היסטוריה" }, { v: "progress", i: "◈", l: "התקדמות" }, { v: "settings", i: "⚙", l: "הגדרות" }].map(n => (
      <button key={n.v} onClick={() => setView(n.v)} style={{ background: "none", border: "none", color: view === n.v ? T.blue : T.dim, cursor: "pointer", textAlign: "center", padding: "4px 10px", fontFamily: font }}>
      <div style={{ fontSize: 18, fontWeight: 300 }}>{n.i}</div><div style={{ fontSize: 10, marginTop: 3, fontWeight: view === n.v ? 700 : 400 }}>{n.l}</div>
      </button>))}
      </div>);
      
      const Card = ({ children, style: s, ...props }) => <div style={{ background: T.card, borderRadius: 16, border: "1px solid " + T.border, backdropFilter: "blur(10px)", ...s }} {...props}>{children}</div>;

      // ═══ HOME ═══
      if (view === "home") return (
      <div dir="rtl" style={{ background: T.bg, minHeight: "100vh", fontFamily: font, color: T.white, paddingBottom: 90 }}>
      <style>{css}</style><Notif /><BackupModal />
      <div style={{ padding: "40px 24px 24px", position: "relative", overflow: "hidden" }}>
      <div style={{ position: "absolute", top: -60, left: -60, width: 200, height: 200, background: "radial-gradient(circle, " + T.blueGlow2 + " 0%, transparent 70%)", borderRadius: "50%" }} />
      <div style={{ position: "relative", display: "flex", justifyContent: "space-between" }}>
      <div><div style={{ fontSize: 12, color: T.dim, letterSpacing: 4, textTransform: "uppercase", fontWeight: 500, marginBottom: 8 }}>Workout Tracker</div><div style={{ fontSize: 32, fontWeight: 900, color: T.white, lineHeight: 1.2 }}>שלום משה</div><div style={{ fontSize: 14, color: T.dim, marginTop: 6, fontWeight: 300 }}>{workouts.length > 0 ? workouts.length + " אימונים מתועדים" : "מוכן להתחיל"}</div></div>
      <button onClick={() => setBackupModal(true)} style={{ background: "rgba(255,255,255,0.06)", border: "1px solid " + T.borderLight, borderRadius: 10, padding: "8px 10px", height: "fit-content", cursor: "pointer", fontSize: 14 }} title="גיבוי">💾 גיבוי</button>
      </div></div>
      <div style={{ padding: "0 24px", marginBottom: 28 }}><Card style={{ padding: 18 }}><div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}><span style={{ fontSize: 14, fontWeight: 700, color: T.white }}>משקל גוף</span></div><div style={{ display: "flex", gap: 10, alignItems: "center" }}><input type="number" placeholder="ק״ג" step="0.1" style={{ ...inputStyle, flex: 1, fontSize: 18, fontFamily: font, fontWeight: 600 }} onKeyDown={async (e) => { if (e.key === "Enter" && e.target.value) { const v = parseFloat(e.target.value); const nb = [{ date: new Date().toISOString(), weight: v }, ...bodyLogs]; setBodyLogs(nb); await persist(workouts, nb, activities, templates, goals); e.target.value = ""; notify(v + " ק״ג ✓"); } }} />{bodyLogs.length > 0 && <div style={{ background: T.blueGlow, borderRadius: 12, padding: "10px 16px", fontSize: 16, fontWeight: 700, color: T.blue, border: "1px solid " + T.border }}>{bodyLogs[0].weight}</div>}</div></Card></div>
