            <div style={{ fontSize: 13, marginBottom: 10, color: T.dim }}>+ הוסף תרגיל חדש לתבנית</div>
            <input placeholder="שם תרגיל (עברית)" value={newEx.name} onChange={e=>setNewEx({...newEx, name: e.target.value})} style={{...inputStyle, marginBottom: 8, textAlign: "right"}} />
            <input placeholder="שם באנגלית (לא חובה)" value={newEx.nameEn} onChange={e=>setNewEx({...newEx, nameEn: e.target.value})} style={{...inputStyle, marginBottom: 8, textAlign: "left", direction: "ltr"}} />
            <div style={{ display: "flex", gap: 8, marginBottom: 8 }}>
              <input type="number" placeholder="סטים (למשל 3)" value={newEx.sets} onChange={e=>setNewEx({...newEx, sets: e.target.value})} style={{...inputStyle}} />
              <input placeholder="חזרות (למשל 8-10)" value={newEx.reps} onChange={e=>setNewEx({...newEx, reps: e.target.value})} style={{...inputStyle, direction: "rtl", textAlign: "right"}} />
            </div>
            <div style={{ display: "flex", gap: 8, marginBottom: 12 }}>
              <select value={newEx.exType} onChange={e=>setNewEx({...newEx, exType: e.target.value})} style={{...inputStyle, flex: 1, color: T.white}}>
                <option value="weight" style={{color: "#000"}}>משקל</option><option value="time" style={{color: "#000"}}>זמן</option>
              </select>
              <label style={{ flex: 1, display: "flex", alignItems: "center", gap: 8, fontSize: 13, color: T.dim }}><input type="checkbox" checked={newEx.hasWarmup} onChange={e=>setNewEx({...newEx, hasWarmup: e.target.checked})} style={{width: 18, height: 18}} /> חימום</label>
            </div>
            <button onClick={() => {
              if(!newEx.name) return notify("חובה להזין שם תרגיל");
              const id = "ex_" + Date.now();
              const toAdd = { id, name: newEx.name, nameEn: newEx.nameEn, sets: parseInt(newEx.sets)||3, reps: newEx.reps, type: newEx.exType, hasWarmup: newEx.hasWarmup };
              saveT({ ...templates, [newEx.type]: [...templates[newEx.type], toAdd] });
              if (!goals[id]) setGoals({...goals, [id]: {value: 0, unit: newEx.exType==="time"?"שנ׳":"ק״ג"}});
              setNewEx({...newEx, name: "", nameEn: ""});
            }} style={{ width: "100%", padding: 10, borderRadius: 8, border: "none", background: T.success, color: "#fff", fontWeight: 700, cursor: "pointer", fontFamily: font }}>הוסף לתבנית {newEx.type}</button>
          </div>
        </Card>

        <div style={{ fontSize: 16, fontWeight: 700, color: T.purple, marginBottom: 10 }}>עריכת יעדים</div>
        <Card style={{ padding: "8px 16px" }}>
          {Object.keys(goals).map(key => {
            const exName = [...templates.A, ...templates.B].find(e => e.id === key)?.name || key;
            if (exName === key && !key.startsWith("ex_")) return null; // Hide old unused goals if any
            return (
            <div key={key} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "8px 0", borderBottom: "1px solid rgba(255,255,255,0.05)" }}>
              <div style={{ fontSize: 14 }}>{exName}</div>
              <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                <input type="number" value={goals[key]?.value||0} onChange={e => { const nv = parseFloat(e.target.value)||0; setGoals({...goals, [key]: {...goals[key], value: nv}}); }} style={{...inputStyle, width: 65, padding: "6px", fontSize: 14}} />
                <span style={{ fontSize: 12, color: T.dim, width: 20 }}>{goals[key]?.unit}</span>
              </div>
            </div>
          )})}
          <button onClick={() => saveG(goals)} style={{ width: "100%", padding: 12, borderRadius: 8, border: "none", background: T.purple, color: "#fff", fontWeight: 700, cursor: "pointer", fontFamily: font, marginTop: 16, marginBottom: 8 }}>שמור יעדים</button>
        </Card>
        </div><Nav /></div>
        );
      }

      return null;
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<WorkoutTracker />);
  </script>
</body>
</html>
